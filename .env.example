# Lemon Squeezy store ID (used for client-side checkout context)
NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=

# Lemon Squeezy checkout identifier or buy-link slug for the product
NEXT_PUBLIC_LEMON_SQUEEZY_PRODUCT_ID=

# Webhook signing secret from Lemon Squeezy dashboard
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Optional: Lemon Squeezy API key if you want server-side API access
LEMON_SQUEEZY_API_KEY=

# GitHub OAuth app credentials (required for private repository scanning)
GITHUB_ID=
GITHUB_SECRET=

# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# OpenAI API key for variable description generation
OPENAI_API_KEY=

# Optional model override (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
